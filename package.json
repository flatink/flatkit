{
  "name": "flatkit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The open language, compiler and player for the FlatInk animation format.",
  "license": "MIT",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "check:english": "node scripts/check-english.mjs",
    "check:pack": "pnpm build && node scripts/check-pack.mjs",
    "verify": "pnpm run lint && pnpm run check:english && pnpm run typecheck && pnpm run test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "publint": "^0.3.21",
    "skia-canvas": "^3.0.8",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "skia-canvas"
    ]
  }
}
