{
  "name": "@flatkit/compiler",
  "version": "0.20.0",
  "description": "The FlatInk language (parser + AST) and compiler (.flatink → .flatpack). Ships the flatc CLI.",
  "license": "MIT",
  "author": "Zwyk Studio",
  "homepage": "http://flatink.zwyk-studio.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flatink/flatkit.git",
    "directory": "packages/compiler"
  },
  "bugs": "https://github.com/flatink/flatkit/issues",
  "keywords": [
    "flatink",
    "flatpack",
    "compiler",
    "cli",
    "flatc",
    "animation"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./compile": "./src/compile.ts",
    "./analysis": "./src/analysis.ts"
  },
  "bin": {
    "flatc": "./bin/flatc.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "dependencies": {
    "@flatkit/engine": "workspace:*",
    "@flatkit/player": "workspace:*",
    "@flatkit/types": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "skia-canvas": "^3.0.8"
  },
  "peerDependenciesMeta": {
    "skia-canvas": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./compile": {
        "types": "./dist/compile.d.ts",
        "import": "./dist/compile.js"
      },
      "./analysis": {
        "types": "./dist/analysis.d.ts",
        "import": "./dist/analysis.js"
      }
    }
  }
}
