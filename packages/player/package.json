{
  "name": "@flatkit/player",
  "version": "0.0.0",
  "description": "The lightweight FlatInk player: load a .flatpack and play it in a <canvas>. No editor, no heavy deps.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "dependencies": {
    "@flatkit/engine": "workspace:*",
    "@flatkit/types": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  }
}
